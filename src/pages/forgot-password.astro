---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Reset Password - My telMAX"
  description="Reset your My telMAX password. Enter your account email and complete a quick security check to receive a reset link."
>
  <section class="section bg-green hero-block">
    <div class="container">
      <div class="hero-block__inner">
        <span class="pill">Account recovery</span>
        <h1>Forgot your password?</h1>
        <p class="lede">
          It happens. Enter the email on your telMAX account and we'll send you a
          secure link to set a new password.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container reset-wrap">
      <div class="card form-card">
        <h3>Reset your password</h3>
        <p class="reset-intro">
          Enter your account email, then complete the quick security check to
          confirm you're human.
        </p>

        <form class="form" id="reset-form" novalidate>
          <label
            >Email address
            <input type="email" name="email" autocomplete="email" required />
          </label>

          <div class="captcha">
            <span class="captcha__label">Security check</span>
            {/* Cloudflare Turnstile. The data-sitekey below is Cloudflare's
                official "always passes" TEST key so it works on localhost.
                Replace it with your real site key from the Cloudflare
                dashboard (Turnstile) before going live. */}
            <div
              class="cf-turnstile"
              data-sitekey="1x00000000000000000000AA"
              data-theme="light"
            >
            </div>
          </div>

          <p class="form-error" id="reset-error" role="alert" hidden></p>

          <button type="submit" class="btn btn--primary">Send reset link</button>

          <p class="form-done" id="reset-done" hidden>
            If an account matches that email, a password reset link is on its way -
            check your inbox. (Demo form: connect it to your account system to send
            real emails.)
          </p>
        </form>

        <p class="reset-back"><a href="/my-telmax">← Back to sign in</a></p>
      </div>
    </div>
  </section>

  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>
</Layout>

<style>
  .hero-block {
    padding-top: clamp(64px, 9vw, 120px);
  }
  .hero-block__inner {
    max-width: 680px;
  }
  .hero-block h1 {
    margin-bottom: 18px;
  }

  .reset-wrap {
    max-width: 520px;
  }
  .reset-intro {
    margin: -6px 0 6px;
    font-size: 0.95rem;
  }
  .reset-back {
    margin-top: 18px;
    font-size: 0.9rem;
  }
  .reset-back a {
    font-weight: 700;
    text-decoration: underline;
  }

  /* Security check (Cloudflare Turnstile) */
  .captcha {
    display: grid;
    gap: 10px;
  }
  .captcha__label {
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-soft);
  }

  .form-error {
    margin: 0;
    background: rgba(205, 34, 37, 0.1);
    color: var(--canada-red);
    font-weight: 600;
    font-size: 0.88rem;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
  }
  .form-error[hidden] {
    display: none;
  }
</style>

<script>
  // Front-end password-reset flow protected by Cloudflare Turnstile.
  // No backend yet - on success it just shows a confirmation. When you wire up
  // a backend, send the Turnstile token (the hidden "cf-turnstile-response"
  // field) to your server and verify it with your Turnstile secret key.
  const form = document.getElementById("reset-form") as HTMLFormElement | null;
  const errorEl = document.getElementById("reset-error");
  const doneEl = document.getElementById("reset-done");

  if (form && errorEl && doneEl) {
    const showError = (message: string) => {
      errorEl.textContent = message;
      errorEl.hidden = false;
    };

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = String(form.email.value || "").trim();
      const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

      if (!emailValid) {
        showError("Please enter a valid email address.");
        return;
      }

      // Turnstile injects a hidden "cf-turnstile-response" input once solved.
      const token = (
        form.querySelector(
          '[name="cf-turnstile-response"]',
        ) as HTMLInputElement | null
      )?.value;
      if (!token) {
        showError("Please complete the security check to continue.");
        return;
      }

      // Passed the checks - confirm to the user (backend wired up later).
      errorEl.hidden = true;
      doneEl.hidden = false;
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;
    });
  }
</script>

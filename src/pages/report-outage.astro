---
import Layout from "../layouts/Layout.astro";
import { SERVICE_OPTIONS, DURATION_OPTIONS } from "../../server/reports.mjs";

/* Where the form POSTs. Defaults to same-origin /report (works when the site is
   served by / proxied to the monitor backend). Set PUBLIC_REPORT_ENDPOINT at
   build time to the backend URL, e.g. the Cloudflare Worker:
     PUBLIC_REPORT_ENDPOINT="https://telmax-status.<you>.workers.dev/report" */
const endpoint = import.meta.env.PUBLIC_REPORT_ENDPOINT || "/report";
---

<Layout
  title="Report an Outage - telMAX"
  description="Report a telMAX service issue at your address. Tell us what's affected and how long it's been happening and our GTA-based team will investigate."
>
  <section class="ro-hero">
    <div class="container">
      <div class="ro-hero__inner">
        <span class="pill">Report an outage</span>
        <h1>Tell us what's going wrong</h1>
        <p class="ro-lede">
          Fill in a few details and our local, GTA-based team will investigate.
          The more you can tell us, the faster we can help.
        </p>
        <p class="ro-check">
          First, it's worth a quick look at the
          <a href="/status">network status board</a> - if there's already an
          alert for your area, we're on it.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container ro-wrap">
      <div class="card form-card ro-card">
        <h2>Outage report</h2>
        <p class="ro-intro">
          Fields marked <em class="ro-req">required</em> help us match the report
          to your location and service. We only use these details to investigate
          and follow up with you.
        </p>

        <form id="ro-form" class="form ro-form" data-endpoint={endpoint} novalidate>
          <div class="field-row">
            <label>
              Full name <em class="ro-req">required</em>
              <input name="name" type="text" autocomplete="name" required />
            </label>
            <label>
              Email address <em class="ro-req">required</em>
              <input name="email" type="email" autocomplete="email" required />
            </label>
          </div>

          <div class="field-row">
            <label>
              Phone number <span class="ro-opt">optional</span>
              <input name="phone" type="tel" autocomplete="tel" maxlength="30" />
            </label>
            <label>
              Service address <em class="ro-req">required</em>
              <input name="address" type="text" autocomplete="street-address"
                placeholder="Street, city" required />
            </label>
          </div>

          <label>
            Which service is affected? <em class="ro-req">required</em>
            <select name="service" required>
              <option value="">Choose a service…</option>
              {SERVICE_OPTIONS.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>

          <label>
            Describe the issue <em class="ro-req">required</em>
            <textarea name="description" rows="5" maxlength="4000" required
              placeholder="What's happening? e.g. no internet at all, TV app won't load, dial tone is dead, keeps dropping every few minutes…"></textarea>
          </label>

          <label>
            How long has this been happening? <em class="ro-req">required</em>
            <select name="duration" required>
              <option value="">Choose an option…</option>
              {DURATION_OPTIONS.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>

          <p class="ro-error" id="ro-error" role="alert" hidden></p>

          <button type="submit" class="btn btn--primary btn--lg" id="ro-submit">
            Submit report
          </button>
          <p class="ro-fine">
            In an emergency always call 911 from a mobile phone. During a power or
            internet outage, telMAX Home Phone (including 911) may be unavailable.
          </p>
        </form>

        <div class="ro-success" id="ro-success" hidden>
          <span class="ro-success__badge" aria-hidden="true"></span>
          <h3>Thanks - your report is logged</h3>
          <p>
            Your reference is <strong id="ro-ref"></strong>. Our team will review
            it and follow up by email. If your issue is urgent, call us any time at
            <a href="tel:18444835629">1-844-483-5629</a> (technical support: ext. 2).
          </p>
          <div class="ro-success__actions">
            <a href="/status" class="btn btn--primary">View network status</a>
            <a href="/support" class="btn btn--outline">Browse troubleshooting</a>
          </div>
        </div>
      </div>

      <aside class="ro-aside">
        <div class="card ro-side-card">
          <h3>Before you file</h3>
          <ul class="ro-list">
            <li>Check the <a href="/status">status board</a> for a known outage in your area.</li>
            <li>Reboot the fibre box (ONT) and your eero - unplug ~15s, ONT back first, then the eero.</li>
            <li>A red <strong>LOS</strong>/alarm light on the fibre box is a line issue - mention it below.</li>
          </ul>
        </div>
        <div class="card ro-side-card">
          <h3>Prefer to talk?</h3>
          <p class="ro-side-line"><span>Call</span><a href="tel:18444835629">1-844-483-5629</a></p>
          <p class="ro-side-line"><span>Email</span><a href="mailto:support@telmax.com">support@telmax.com</a></p>
          <p class="ro-side-note">Our network is monitored 24/7.</p>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  /* Banner hero - background image behind a deep-green gradient, like /support */
  .ro-hero {
    position: relative;
    background:
      radial-gradient(900px 380px at 85% -10%, rgba(183, 181, 245, 0.18), transparent 70%),
      linear-gradient(180deg, rgba(27, 61, 56, 0.82) 0%, rgba(27, 61, 56, 0.88) 55%, rgba(27, 61, 56, 0.95) 100%),
      url("/images/photos/detail-fibre-optic.webp") center / cover no-repeat,
      var(--deep-green);
    color: var(--cream);
    padding: clamp(76px, 11vw, 148px) 0 clamp(56px, 8vw, 100px);
  }
  .ro-hero__inner { max-width: 640px; }
  .ro-hero .pill { margin-bottom: 22px; }
  .ro-hero h1 {
    color: var(--cream);
    font-size: clamp(2.3rem, 4.8vw, 3.6rem);
    margin: 0 0 22px;
  }
  .ro-lede {
    color: rgba(249, 249, 235, 0.86);
    font-size: 1.18rem;
    line-height: 1.55;
    max-width: 560px;
    margin: 0;
  }
  .ro-check {
    margin-top: 20px;
    font-size: 0.95rem;
    color: rgba(249, 249, 235, 0.75);
  }
  .ro-check a { color: var(--lime); font-weight: 700; text-decoration: underline; }

  .ro-wrap {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .ro-card { padding: clamp(24px, 3vw, 38px); }
  .ro-card h2 { font-size: clamp(1.5rem, 2.6vw, 2rem); }
  .ro-intro { margin: 10px 0 22px; font-size: 0.95rem; }
  .ro-form { gap: 18px; }
  .ro-form textarea { min-height: 128px; }

  .ro-req, .ro-opt {
    font-style: normal;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: 4px;
  }
  .ro-req { color: var(--canada-red); }
  .ro-opt { color: var(--green-soft); font-weight: 600; opacity: 0.75; }

  .ro-error {
    margin: 0;
    background: rgba(205, 34, 37, 0.1);
    color: var(--canada-red);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 11px 15px;
    border-radius: var(--radius-sm);
  }
  .ro-error[hidden] { display: none; }
  .ro-fine { margin-top: 4px; font-size: 0.8rem; color: var(--green-soft); }

  #ro-submit { justify-self: start; }
  #ro-submit:disabled { opacity: 0.6; cursor: default; transform: none; }

  /* Success state */
  .ro-success { text-align: center; padding: 8px 0 4px; }
  .ro-success[hidden] { display: none; }
  .ro-success__badge {
    width: 62px; height: 62px; margin: 0 auto 12px;
    border-radius: 50%; display: block;
    background:
      url("/images/icons/check.svg") center / 28px no-repeat,
      var(--lime);
  }
  .ro-success h3 { font-size: 1.5rem; }
  .ro-success p { max-width: 460px; margin: 10px auto 0; }
  .ro-success strong { color: var(--deep-green); font-variant-numeric: tabular-nums; }
  .ro-success__actions {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 22px;
  }

  /* Aside */
  .ro-aside { display: grid; gap: 20px; }
  .ro-side-card { padding: 24px; }
  .ro-side-card h3 { font-size: 1.15rem; margin-bottom: 12px; }
  .ro-list { display: grid; gap: 10px; }
  .ro-list li {
    position: relative; padding-left: 22px;
    font-size: 0.9rem; color: var(--green-soft); line-height: 1.5;
  }
  .ro-list li::before {
    content: ""; position: absolute; left: 0; top: 7px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--lime); border: 2px solid var(--deep-green);
  }
  .ro-list a { color: var(--deep-green); font-weight: 700; text-decoration: underline; }
  .ro-side-line {
    display: flex; justify-content: space-between; gap: 12px;
    padding: 9px 0; border-bottom: 1px solid var(--green-line);
    font-size: 0.95rem;
  }
  .ro-side-line span { color: var(--green-soft); font-weight: 600; }
  .ro-side-line a { font-weight: 700; color: var(--deep-green); }
  .ro-side-note { margin-top: 12px; font-size: 0.85rem; color: var(--green-soft); }

  @media (max-width: 900px) {
    .ro-wrap { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById("ro-form") as HTMLFormElement | null;
  if (form) {
    const endpoint = form.dataset.endpoint || "/report";
    const errEl = document.getElementById("ro-error");
    const successEl = document.getElementById("ro-success");
    const refEl = document.getElementById("ro-ref");
    const submitBtn = document.getElementById("ro-submit") as HTMLButtonElement | null;
    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const fields = [...form.querySelectorAll("input, select, textarea")].filter(
      (f) => (f as HTMLInputElement).type !== "hidden",
    ) as (HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)[];

    const labelOf = (f: Element) => f.closest("label") || f.parentElement;
    function clearError(f: Element) {
      f.removeAttribute("aria-invalid");
      labelOf(f)?.querySelector(".field-error")?.remove();
    }
    function setError(f: Element, message: string) {
      f.setAttribute("aria-invalid", "true");
      const label = labelOf(f);
      if (!label) return;
      let note = label.querySelector(".field-error");
      if (!note) {
        note = document.createElement("small");
        note.className = "field-error";
        label.appendChild(note);
      }
      note.textContent = message;
    }
    const showError = (msg: string) => {
      if (!errEl) return;
      errEl.textContent = msg;
      errEl.hidden = false;
    };

    function validate(f: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) {
      const v = (f.value || "").trim();
      if (f.name === "email") {
        if (!v) return "Please enter your email address.";
        if (!EMAIL_RE.test(v)) return "Please enter a valid email address.";
        return null;
      }
      if (f.name === "description") return v.length < 5 ? "Please describe the issue (a few words is fine)." : null;
      if ((f as HTMLInputElement).required && !v) return "Please complete this field.";
      return null;
    }

    fields.forEach((f) =>
      f.addEventListener("input", () => { clearError(f); if (errEl) errEl.hidden = true; }, { passive: true }),
    );

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (errEl) errEl.hidden = true;

      let firstInvalid: Element | null = null;
      for (const f of fields) {
        const message = validate(f);
        if (message) { setError(f, message); if (!firstInvalid) firstInvalid = f; }
        else clearError(f);
      }
      if (firstInvalid) { (firstInvalid as HTMLElement).focus(); return; }

      const payload = {
        name: (form.elements.namedItem("name") as HTMLInputElement).value,
        email: (form.elements.namedItem("email") as HTMLInputElement).value,
        phone: (form.elements.namedItem("phone") as HTMLInputElement).value,
        address: (form.elements.namedItem("address") as HTMLInputElement).value,
        service: (form.elements.namedItem("service") as HTMLSelectElement).value,
        description: (form.elements.namedItem("description") as HTMLTextAreaElement).value,
        duration: (form.elements.namedItem("duration") as HTMLSelectElement).value,
      };

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = "Submitting…"; }
      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          if (refEl) refEl.textContent = data.id || "";
          form.hidden = true;
          if (successEl) {
            successEl.hidden = false;
            successEl.scrollIntoView({ behavior: "smooth", block: "center" });
          }
          return;
        }
        showError(
          data.error ||
            "Sorry, we couldn't submit your report just now. Please try again, or call 1-844-483-5629.",
        );
      } catch {
        showError(
          "We couldn't reach the reporting service. Please check your connection and try again, or call 1-844-483-5629.",
        );
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Submit report"; }
      }
    });
  }
</script>

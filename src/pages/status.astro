---
import Layout from "../layouts/Layout.astro";
import "../styles/status.css";

/*
 * Network Status page.
 * The board is the server-rendered fallback (shown with JS off). On load a
 * client script fetches /status.json, re-renders the board with live data,
 * and refreshes every 60s. Edit public/status.json to change what visitors
 * see - no rebuild required. Styling lives in styles/status.css (GLOBAL), so
 * the JS-rendered board is styled the same as this fallback.
 */
const LABEL = {
  operational: "Operational",
  maintenance: "Maintenance",
  degraded: "Degraded",
  outage: "Outage",
};

const services = [
  { name: "MAXfibre Internet", note: "Pure fibre network", status: "operational" },
  { name: "MAXview TV", note: "Live TV, apps and Cloud-PVR", status: "operational" },
  { name: "MAXtalk Home Phone", note: "Calling and voicemail", status: "operational" },
  { name: "My telMAX", note: "Account portal and billing", status: "operational" },
];

const areas = [
  "Aurora", "Barrie", "Brooklin", "Markham",
  "Newmarket", "Richmond Hill", "Stouffville",
].map((name) => ({ name, status: "operational" }));

const updated = new Date().toLocaleString("en-CA", {
  dateStyle: "long",
  timeStyle: "short",
  timeZone: "America/Toronto",
});

const checkSteps = [
  {
    icon: "wifi",
    title: "Check this page first",
    text: "If we're aware of an outage in your area, we'll show it here. No alert usually means the issue is local to your home.",
  },
  {
    icon: "wrench",
    title: "Reboot your equipment",
    text: "Unplug the fibre box (ONT) and your eero for about 15 seconds, plug the fibre box back in first, let it settle, then power the eero on.",
  },
  {
    icon: "phone-ring",
    title: "Still down? Tell us",
    text: "If your equipment is healthy and there's no alert above, report it and our GTA-based team will investigate.",
  },
];
---

<Layout
  title="Network Status - telMAX"
  description="Check the live status of telMAX internet, TV, home phone and My telMAX across the GTA - by service and by area - and learn how to report an outage."
>
  <section class="section bg-green hero-block">
    <div class="container">
      <div class="hero-block__inner">
        <span class="pill">Network Status</span>
        <h1>telMAX network status</h1>
        <p class="lede">
          A live look at how our services are running across the GTA - and what
          to do if something isn't working at your home.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div id="status-app" class="status-app">
        <!-- Server-rendered fallback (all operational). JS replaces this with live data. -->
        <div class="status-overall is-operational">
          <span class="status-ind" aria-hidden="true"></span>
          <div class="status-overall__text">
            <strong>All systems operational</strong>
            <span>No outages are currently reported across the telMAX network.</span>
          </div>
          <div class="status-overall__meta">
            <span class="status-live">Live</span>
            <span class="status-updated-time">Updated {updated} (ET)</span>
          </div>
        </div>

        <div class="status-legend" aria-hidden="true">
          <span class="status-legend__item"><span class="st-dot is-operational"></span>Operational</span>
          <span class="status-legend__item"><span class="st-dot is-maintenance"></span>Maintenance</span>
          <span class="status-legend__item"><span class="st-dot is-degraded"></span>Degraded</span>
          <span class="status-legend__item"><span class="st-dot is-outage"></span>Outage</span>
        </div>

        <section class="status-sec">
          <h2 class="status-sec__title">Services</h2>
          <ul class="status-list">
            {
              services.map((s) => (
                <li class="status-row">
                  <span class="status-svc">
                    <span class="status-svc__name">{s.name}</span>
                    <span class="status-svc__note">{s.note}</span>
                  </span>
                  <span class={`st-pill is-${s.status}`}>
                    <span class="st-dot" aria-hidden="true" />
                    {LABEL[s.status]}
                  </span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="status-sec">
          <h2 class="status-sec__title">Service areas</h2>
          <div class="status-areas">
            {
              areas.map((a) => (
                <div class={`status-area is-${a.status}`}>
                  <span class="status-area__head">
                    <span class="st-dot" aria-hidden="true" />
                    <span class="status-area__name">{a.name}</span>
                  </span>
                  <span class="status-area__label">{LABEL[a.status]}</span>
                </div>
              ))
            }
          </div>
        </section>

        <p class="status-note">
          Seeing a problem that isn't listed? <a href="#report">Report an outage</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-lime status-steps">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Experiencing an issue?</span>
        <h2>Three quick things to try</h2>
      </div>
      <div class="grid grid-3">
        {
          checkSteps.map((c) => (
            <div class="feat">
              <span class="icon-chip">
                <span class="icon-mask" style={`--src:url('/images/icons/${c.icon}.svg')`} />
              </span>
              <h3>{c.title}</h3>
              <p>{c.text}</p>
            </div>
          ))
        }
      </div>
      <p class="status-hint">
        Need step-by-step help first? Browse
        <a href="/support#p/internet/troubleshooting">internet troubleshooting</a>
        in the Support Centre.
      </p>
    </div>
  </section>

  <section class="section bg-green" id="report">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Report an outage</span>
        <h2>Let our local team know</h2>
        <p>
          If your equipment is healthy and there's no alert above, contact us and
          we'll investigate right away. Our network is monitored 24/7.
        </p>
      </div>
      <div class="grid grid-2 status-contact">
        <a href="tel:18444835629" class="card s-contact">
          <span class="icon-chip"><span class="icon-mask" style="--src:url('/images/icons/phone.svg')"></span></span>
          <h3>Call us</h3>
          <strong>1-844-483-5629</strong>
          <p>Technical support: ext. 2</p>
        </a>
        <a href="mailto:support@telmax.com" class="card s-contact">
          <span class="icon-chip"><span class="icon-mask" style="--src:url('/images/icons/email.svg')"></span></span>
          <h3>Email us</h3>
          <strong>support@telmax.com</strong>
          <p>We reply within one business day</p>
        </a>
      </div>
      <p class="status-911">
        <strong>A note on Home Phone:</strong> during a power or internet outage,
        telMAX Home Phone - including 911 calling - may be unavailable. Keep a
        charged mobile phone on hand for emergencies.
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero-block { padding-top: clamp(64px, 9vw, 120px); }
  .hero-block__inner { max-width: 680px; }
</style>

<script>
  // Live status: fetch /status.json, re-render the board, refresh every 60s.
  // The server-rendered board stays as the no-JS fallback.
  const app = document.getElementById("status-app");
  if (app) {
    const ORDER = ["operational", "maintenance", "degraded", "outage"];
    const LABEL = { operational: "Operational", maintenance: "Maintenance", degraded: "Degraded", outage: "Outage" };
    const OVERALL = {
      operational: { banner: "All systems operational", sub: "No outages are currently reported across the telMAX network." },
      maintenance: { banner: "Scheduled maintenance underway", sub: "Some services may be briefly affected during planned maintenance." },
      degraded: { banner: "Some services are experiencing issues", sub: "We're aware of a problem affecting one or more services or areas and are working on it." },
      outage: { banner: "Service disruption", sub: "We're investigating an outage affecting one or more services or areas." },
    };
    const key = (k) => (LABEL[k] ? k : "operational");
    const esc = (s) =>
      String(s == null ? "" : s).replace(/[&<>"']/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[m]));
    const fmt = (iso) => { const d = new Date(iso); return isNaN(d.getTime()) ? "" : d.toLocaleString("en-CA", { dateStyle: "medium", timeStyle: "short", timeZone: "America/Toronto" }); };
    const fmtLong = (iso) => { const d = iso ? new Date(iso) : new Date(); return (isNaN(d.getTime()) ? new Date() : d).toLocaleString("en-CA", { dateStyle: "long", timeStyle: "short", timeZone: "America/Toronto" }); };

    function render(data) {
      const services = Array.isArray(data.services) ? data.services : [];
      const areas = Array.isArray(data.areas) ? data.areas : [];
      const incidents = (Array.isArray(data.incidents) ? data.incidents : []).filter(Boolean);

      let worst = "operational";
      services.concat(areas).forEach((x) => { const k = key(x.status); if (ORDER.indexOf(k) > ORDER.indexOf(worst)) worst = k; });
      const overallKey = LABEL[data.overall] ? data.overall : worst;
      const ov = OVERALL[overallKey] || OVERALL.operational;

      const legend = `<div class="status-legend" aria-hidden="true">${ORDER
        .map((k) => `<span class="status-legend__item"><span class="st-dot is-${k}"></span>${LABEL[k]}</span>`)
        .join("")}</div>`;

      const incidentsHTML = incidents.length
        ? `<section class="status-sec"><h2 class="status-sec__title">Active incidents</h2><div class="status-incidents">${incidents
            .map((inc) => {
              const k = key(inc.status);
              return `<div class="status-incident is-${k}">
                <div class="status-incident__head">
                  <span class="st-pill is-${k}"><span class="st-dot" aria-hidden="true"></span>${esc(LABEL[k])}</span>
                  <strong>${esc(inc.title || "")}</strong>
                </div>
                ${inc.body ? `<p>${esc(inc.body)}</p>` : ""}
                ${inc.time ? `<span class="status-incident__time">Updated ${esc(fmt(inc.time))}</span>` : ""}
              </div>`;
            })
            .join("")}</div></section>`
        : "";

      const servicesHTML = `<section class="status-sec"><h2 class="status-sec__title">Services</h2><ul class="status-list">${services
        .map((s) => {
          const k = key(s.status);
          return `<li class="status-row">
            <span class="status-svc">
              <span class="status-svc__name">${esc(s.name)}</span>
              ${s.note ? `<span class="status-svc__note">${esc(s.note)}</span>` : ""}
            </span>
            <span class="st-pill is-${k}"><span class="st-dot" aria-hidden="true"></span>${esc(LABEL[k])}</span>
          </li>`;
        })
        .join("")}</ul></section>`;

      const areasHTML = areas.length
        ? `<section class="status-sec"><h2 class="status-sec__title">Service areas</h2><div class="status-areas">${areas
            .map((a) => {
              const k = key(a.status);
              return `<div class="status-area is-${k}">
                <span class="status-area__head">
                  <span class="st-dot" aria-hidden="true"></span>
                  <span class="status-area__name">${esc(a.name)}</span>
                </span>
                <span class="status-area__label">${esc(LABEL[k])}</span>
              </div>`;
            })
            .join("")}</div></section>`
        : "";

      app.innerHTML = `
        <div class="status-overall is-${overallKey}">
          <span class="status-ind" aria-hidden="true"></span>
          <div class="status-overall__text">
            <strong>${esc(ov.banner)}</strong>
            <span>${esc(ov.sub)}</span>
          </div>
          <div class="status-overall__meta">
            <span class="status-live">Live</span>
            <span class="status-updated-time">Updated ${esc(fmtLong(data.updated))} (ET)</span>
          </div>
        </div>
        ${legend}
        ${incidentsHTML}
        ${servicesHTML}
        ${areasHTML}
        <p class="status-note">Seeing a problem that isn't listed? <a href="#report">Report an outage</a>.</p>`;
    }

    async function load() {
      try {
        const res = await fetch(`/status.json?t=${Date.now()}`, { cache: "no-store" });
        if (!res.ok) return;
        render(await res.json());
      } catch (e) {
        /* keep the server-rendered fallback */
      }
    }

    load();
    setInterval(() => { if (!document.hidden) load(); }, 60000);
    document.addEventListener("visibilitychange", () => { if (!document.hidden) load(); });
  }
</script>

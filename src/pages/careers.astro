---
import Layout from "../layouts/Layout.astro";

const perks = [
  { icon: "maple-leaf", title: "Build something Canadian", text: "Help grow a homegrown network that's redefining connectivity across the GTA." },
  { icon: "user-group", title: "A team that collaborates", text: "Agility and collaboration are core values - your ideas are heard and acted on." },
  { icon: "graph", title: "Room to grow", text: "We invest in our people with real opportunities to learn and advance." },
  { icon: "maple-leaf-outline", title: "Community-minded", text: "We support the neighbourhoods we serve, and we hire from them too." },
];

const openings = [
  { title: "Fibre Network Technician", type: "Full-time", location: "GTA" },
  { title: "Customer Support Representative", type: "Full-time", location: "Newmarket, ON" },
  { title: "Field Installation Specialist", type: "Full-time", location: "GTA" },
  { title: "Business Account Manager", type: "Full-time", location: "Aurora, ON" },
];
---

<Layout
  title="Careers - telMAX"
  description="Join the telMAX team and help build Canada's fastest pure fibre network."
>
  <section class="section bg-green hero-block">
    <div class="container">
      <div class="hero-block__inner">
        <span class="pill">Careers</span>
        <h1>Help us build what's next.</h1>
        <p class="lede">
          We're a growing team of builders, problem-solvers and locals who care
          about doing connectivity right. Come grow with us.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Why telMAX</span>
        <h2>A place to do your best work</h2>
      </div>
      <div class="grid grid-4">
        {
          perks.map((p) => (
            <div class="feat">
              <span class="icon-chip">
                <span class="icon-mask" style={`--src:url('/images/icons/${p.icon}.svg')`} />
              </span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section bg-lime">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Open roles</span>
        <h2>Current opportunities</h2>
      </div>
      <div class="jobs">
        {
          openings.map((j) => (
            <div class="job card">
              <div>
                <h3>{j.title}</h3>
                <span class="job__meta">{j.type} · {j.location}</span>
              </div>
              <a href="/contact" class="btn btn--outline">Apply now</a>
            </div>
          ))
        }
      </div>
      <p class="text-center" style="margin-top:24px;font-size:0.9rem;color:var(--green-soft)">
        Don't see your role? Send your resume to <a href="mailto:careers@telmax.com" style="font-weight:700;text-decoration:underline">careers@telmax.com</a>.
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero-block { padding-top: clamp(64px, 9vw, 120px); }
  .hero-block__inner { max-width: 680px; }
  .jobs { display: grid; gap: 14px; max-width: 820px; margin: 0 auto; }
  .job { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .job__meta { color: var(--green-soft); font-weight: 600; font-size: 0.9rem; }
  @media (max-width: 520px) {
    .job { flex-direction: column; align-items: flex-start; }
  }
</style>

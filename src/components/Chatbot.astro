---
/**
 * telMAX assistant - a small chatbot widget pinned to the bottom-right.
 * Markup is static; all interaction lives in src/scripts/chatbot.js.
 * Styles are global (is:global) because the chat body is rendered by JS,
 * and Astro's scoped styles only reach server-rendered markup.
 */
---

<div class="cb" id="telmax-chatbot">
  <div class="cb-panel" role="dialog" aria-label="telMAX assistant">
    <header class="cb-header">
      <button class="cb-back" type="button" aria-label="Go back" hidden>
        <span class="cb-back__icon" aria-hidden="true"></span>
      </button>
      <div class="cb-ident">
        <span class="cb-ident__av" aria-hidden="true"></span>
        <span class="cb-ident__text">
          <strong>telMAX Assistant</strong>
          <span class="cb-ident__status">Online now</span>
        </span>
      </div>
      <button class="cb-close" type="button" aria-label="Close chat">
        <span class="cb-close__icon" aria-hidden="true"></span>
      </button>
    </header>
    <div class="cb-body" aria-live="polite"></div>
    <p class="cb-foot">Powered by telMAX</p>
  </div>

  <button
    class="cb-fab"
    type="button"
    aria-label="Open the telMAX assistant"
    aria-expanded="false"
  >
    <span class="cb-fab__mark cb-fab__mark--logo" aria-hidden="true"></span>
    <span class="cb-fab__mark cb-fab__mark--close" aria-hidden="true"></span>
  </button>
</div>

<style is:global>
  /* ===================== telMAX chatbot widget ===================== */
  .cb {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 1000;
    font-family: var(--sans);
  }

  /* ---- Floating action button ---- */
  .cb-fab {
    position: relative;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(155deg, #e9f3ec, #c7e3d1);
    border: 1px solid rgba(27, 61, 56, 0.14);
    box-shadow: 0 14px 30px -10px rgba(27, 61, 56, 0.45);
    cursor: pointer;
    transition:
      transform 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out),
      background 0.3s ease;
  }
  .cb-fab:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 20px 38px -12px rgba(27, 61, 56, 0.5);
  }
  .cb-fab:active { transform: scale(0.97); }
  .cb-fab__mark {
    grid-area: 1 / 1;
    transition:
      opacity 0.25s ease,
      transform 0.35s var(--ease-out);
  }
  .cb-fab__mark--logo {
    width: 42px;
    height: 42px;
    background: var(--deep-green);
    -webkit-mask: url("/images/logos/telmax.svg") center / contain no-repeat;
    mask: url("/images/logos/telmax.svg") center / contain no-repeat;
  }
  .cb-fab__mark--close {
    width: 22px;
    height: 22px;
    background: var(--cream);
    opacity: 0;
    transform: rotate(-90deg);
    -webkit-mask: url("/images/icons/chevron-down.svg") center / contain no-repeat;
    mask: url("/images/icons/chevron-down.svg") center / contain no-repeat;
  }
  .cb-open .cb-fab {
    background: var(--deep-green);
    border-color: var(--deep-green);
  }
  .cb-open .cb-fab__mark--logo {
    opacity: 0;
    transform: rotate(90deg);
  }
  .cb-open .cb-fab__mark--close {
    opacity: 1;
    transform: rotate(0);
  }
  /* The telMAX logo gently breathes so the launcher feels alive.
     Runs only while closed, so it never fights the open/close rotation. */
  .cb:not(.cb-open) .cb-fab__mark--logo {
    animation: cb-logo-breathe 3s ease-in-out infinite;
  }
  @keyframes cb-logo-breathe {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-1.5px) scale(1.12);
    }
  }

  /* ---- Panel ---- */
  .cb-panel {
    position: absolute;
    right: 0;
    bottom: 78px;
    width: min(372px, calc(100vw - 32px));
    height: min(560px, calc(100vh - 132px));
    display: flex;
    flex-direction: column;
    background: var(--cream);
    border: 1px solid var(--green-line);
    border-radius: 22px;
    box-shadow: 0 32px 64px -24px rgba(27, 61, 56, 0.55);
    overflow: hidden;
    transform-origin: bottom right;
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px) scale(0.96);
    transition:
      opacity 0.26s var(--ease-out),
      transform 0.26s var(--ease-out),
      visibility 0.26s;
  }
  .cb-open .cb-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* ---- Header ---- */
  .cb-header {
    flex: none;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 14px;
    background: var(--deep-green);
    color: var(--cream);
  }
  .cb-ident {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }
  .cb-ident__av {
    position: relative;
    width: 40px;
    height: 40px;
    flex: none;
    border-radius: 50%;
    background: linear-gradient(155deg, #e9f3ec, #c7e3d1);
  }
  .cb-ident__av::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--deep-green);
    -webkit-mask: url("/images/logos/telmax.svg") center / 28px no-repeat;
    mask: url("/images/logos/telmax.svg") center / 28px no-repeat;
  }
  .cb-ident__text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .cb-ident__text strong {
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 600;
  }
  .cb-ident__status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.74rem;
    color: rgba(249, 249, 235, 0.72);
  }
  .cb-ident__status::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #57d98a;
    box-shadow: 0 0 0 3px rgba(87, 217, 138, 0.25);
  }
  .cb-back,
  .cb-close {
    width: 34px;
    height: 34px;
    flex: none;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(249, 249, 235, 0.12);
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .cb-back:hover,
  .cb-close:hover { background: rgba(249, 249, 235, 0.24); }
  .cb-back[hidden] { display: none; }
  .cb-back__icon {
    width: 16px;
    height: 16px;
    background: var(--cream);
    -webkit-mask: url("/images/icons/arrow-left.svg") center / contain no-repeat;
    mask: url("/images/icons/arrow-left.svg") center / contain no-repeat;
  }
  .cb-close__icon {
    position: relative;
    width: 16px;
    height: 16px;
  }
  .cb-close__icon::before,
  .cb-close__icon::after {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 16px;
    height: 2px;
    border-radius: 2px;
    background: var(--cream);
  }
  .cb-close__icon::before { transform: rotate(45deg); }
  .cb-close__icon::after { transform: rotate(-45deg); }

  /* ---- Body ---- */
  .cb-body {
    flex: 1;
    overflow-y: auto;
    padding: 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background:
      radial-gradient(
        440px 220px at 100% 0%,
        rgba(183, 181, 245, 0.13),
        transparent 70%
      ),
      var(--cream);
  }
  .cb-body::-webkit-scrollbar { width: 8px; }
  .cb-body::-webkit-scrollbar-thumb {
    background: rgba(27, 61, 56, 0.22);
    border-radius: 999px;
  }

  .cb-turn {
    display: flex;
    gap: 9px;
    align-items: flex-end;
  }
  .cb-turn__av {
    position: relative;
    width: 30px;
    height: 30px;
    flex: none;
    border-radius: 50%;
    background: linear-gradient(155deg, #e9f3ec, #c7e3d1);
  }
  .cb-turn__av::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--deep-green);
    -webkit-mask: url("/images/logos/telmax.svg") center / 21px no-repeat;
    mask: url("/images/logos/telmax.svg") center / 21px no-repeat;
  }
  .cb-turn__msgs {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .cb-bubble {
    margin: 0;
    background: var(--white);
    border: 1px solid var(--green-line);
    border-radius: 16px 16px 16px 5px;
    padding: 11px 14px;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--deep-green);
    box-shadow: 0 4px 12px -8px rgba(27, 61, 56, 0.4);
  }

  /* ---- Option choices ---- */
  .cb-choices {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cb-choice {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    width: 100%;
    text-align: left;
    background: var(--white);
    border: 1.5px solid var(--green-line);
    border-radius: 13px;
    padding: 12px 14px;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--deep-green);
    cursor: pointer;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      transform 0.18s var(--ease-out);
  }
  .cb-choice:hover {
    border-color: var(--deep-green);
    background: var(--lime);
    transform: translateX(3px);
  }
  .cb-choice__arrow {
    width: 15px;
    height: 15px;
    flex: none;
    background: var(--deep-green);
    -webkit-mask: url("/images/icons/arrow-right.svg") center / contain no-repeat;
    mask: url("/images/icons/arrow-right.svg") center / contain no-repeat;
    transition: transform 0.18s ease;
  }
  .cb-choice:hover .cb-choice__arrow { transform: translateX(3px); }
  .cb-choice--link {
    background: var(--deep-green);
    color: var(--cream);
    border-color: var(--deep-green);
  }
  .cb-choice--link .cb-choice__arrow { background: var(--cream); }
  .cb-choice--link:hover {
    background: var(--green-soft);
    border-color: var(--green-soft);
  }

  /* ---- Form ---- */
  .cb-form {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .cb-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cb-field__label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--deep-green);
  }
  .cb-req,
  .cb-opt {
    font-style: normal;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .cb-req { color: var(--canada-red); }
  .cb-opt {
    color: var(--green-soft);
    font-weight: 600;
    opacity: 0.75;
  }
  .cb-input {
    width: 100%;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--deep-green);
    background: var(--white);
    border: 1.5px solid var(--green-line);
    border-radius: 10px;
    padding: 10px 12px;
  }
  .cb-input:focus {
    outline: 2px solid var(--deep-green);
    outline-offset: 1px;
  }
  .cb-error {
    margin: 2px 0 0;
    background: rgba(205, 34, 37, 0.1);
    color: var(--canada-red);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 8px 11px;
    border-radius: 9px;
  }
  .cb-error[hidden] { display: none; }
  .cb-submit {
    margin-top: 4px;
    background: var(--deep-green);
    color: var(--cream);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 18px;
    border-radius: 999px;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s var(--ease-out);
  }
  .cb-submit:hover {
    background: var(--green-soft);
    transform: translateY(-2px);
  }

  /* ---- Contact details ---- */
  .cb-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cb-contact__row {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--white);
    border: 1.5px solid var(--green-line);
    border-radius: 12px;
    padding: 11px 14px;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .cb-contact__row:hover {
    border-color: var(--deep-green);
    background: var(--lime);
  }
  .cb-contact__k {
    font-size: 0.71rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--green-soft);
  }
  .cb-contact__v {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--deep-green);
  }

  /* ---- Footer ---- */
  .cb-foot {
    flex: none;
    margin: 0;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--green-soft);
    padding: 9px;
    background: var(--white);
    border-top: 1px solid var(--green-line);
  }

  /* ---- Staggered fade-in for chat content ----
     Each rendered element carries a --cb-i index, so messages and then
     options cascade into view one after another. */
  .cb-anim {
    animation: cb-in 0.42s var(--ease-out) backwards;
    animation-delay: calc(0.1s + var(--cb-i, 0) * 0.06s);
  }
  @keyframes cb-in {
    from {
      opacity: 0;
      transform: translateY(9px);
    }
  }

  @media (max-width: 480px) {
    .cb {
      right: 16px;
      bottom: 16px;
    }
    .cb-panel {
      height: min(540px, calc(100vh - 116px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-fab,
    .cb-fab__mark,
    .cb-panel,
    .cb-anim,
    .cb-choice,
    .cb-choice__arrow,
    .cb-submit {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  import { initChatbot } from "../scripts/chatbot.mjs";
  const root = document.getElementById("telmax-chatbot");
  if (root) initChatbot(root);
</script>
